   "source": [
    "## 4. User access code 4"
   ]
  },
  {
   "cell_type": "raw",
   "id": "02758f92",
   "metadata": {},
   "source": [
    "SELECT\n",
    "  (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST(user_properties)\n",
    "  WHERE\n",
    "    key = \"user_id\") AS user_id,\n",
    "FROM\n",
    "  `project.dataset.events_*`\n",
    "WHERE\n",
    "  event_name='user_access_code'\n",
    "LIMIT\n",
    "  1000"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "96a40418",
   "metadata": {},
   "source": [
    "## 5. Video Start Query "
   ]
  },
  {
   "cell_type": "raw",
   "id": "f12cb9df",
   "metadata": {},
   "source": [
    " -- select event_date, user_id, (select value.string_value from unnest(user_properties) where key='email') as email from `project.dataset.events_*` where event_name = \"video_start\" order by event_date\n",
    "WITH\n",
    "  users AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    event_name,\n",
    "    user_id,\n",
    "    event_timestamp,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key=\"video_title\") AS video_title\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  all_video_start AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id,\n",
    "    event_timestamp,\n",
    "    video_title\n",
    "  FROM\n",
    "    users\n",
    "  WHERE\n",
    "    event_name = \"video_start\"),\n",
    "  all_video_complete AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id,\n",
    "    event_timestamp,\n",
    "    video_title\n",
    "  FROM\n",
    "    users\n",
    "  WHERE\n",
    "    event_name = \"complete_watch_video\"),\n",
    "  all_video_start_count AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    COUNT(event_date) count_start\n",
    "  FROM\n",
    "    all_video_start\n",
    "  GROUP BY\n",
    "    event_date\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  all_video_complete_count AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    COUNT(event_date) count_complete\n",
    "  FROM\n",
    "    all_video_complete\n",
    "  GROUP BY\n",
    "    event_date\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "SELECT\n",
    "  t1.event_date,\n",
    "  t1.count_start,\n",
    "  t2.count_complete\n",
    "FROM\n",
    "  all_video_start_count AS t1\n",
    "JOIN\n",
    "  all_video_complete_count AS t2\n",
    "ON\n",
    "  t1.event_date=t2.event_date\n",
    "ORDER BY\n",
    "  t1.event_date DESC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4a8846f6",
   "metadata": {},
   "source": [
    "## 6. Access code Except sth"
   ]
  },
  {
   "cell_type": "raw",
   "id": "263746e1",
   "metadata": {},
   "source": [
    "SELECT\n",
    "event_date,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "      (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"name\") AS name,\n",
    "      (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"access_code\") AS access_code,\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='user_access_code'\n",
    "    AND (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"access_code\") NOT IN ('sth1', 'sth2', 'sth3')\n",
    "\n",
    "      ORDER BY event_date DESC"
   ]
