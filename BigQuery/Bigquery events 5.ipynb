   "source": [
    "## 1. Sample Table"
   ]
  },
  {
   "cell_type": "raw",
   "id": "9134f4fa",
   "metadata": {},
   "source": [
    "WITH Players AS\n",
    "(SELECT 'Ronaldo' AS PlayerName, 35 AS AGE, 93 AS Rating UNION ALL\n",
    "SELECT 'Messi', 34, 92 UNION ALL\n",
    "SELECT 'Havertz', 37, 88 UNION ALL\n",
    "SELECT 'Müller', 42, 89)\n",
    "\n",
    "SELECT * FROM Players"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5b102bff",
   "metadata": {},
   "source": [
    "## 2. Screen type that user has spent on "
   ]
  },
  {
   "cell_type": "raw",
   "id": "8190bd8f",
   "metadata": {},
   "source": [
    "WITH  screen_type AS (SELECT\n",
    " (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST (event_params)\n",
    "  WHERE\n",
    "    Key='firebase_screen') AS screens, COUNT ((\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST (event_params)\n",
    "  WHERE\n",
    "    Key='firebase_screen')) AS count_number\n",
    "FROM\n",
    "  `project.dataset.events_*`\n",
    "WHERE\n",
    "  event_name='screen_view'\n",
    "  AND (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST (event_params)\n",
    "  WHERE\n",
    "    Key='firebase_screen') IS NOT NULL\n",
    "    GROUP BY screens\n",
    "    ORDer by count_number DESC)\n",
    "\n",
    "    SELECT * FROM screen_type"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b8f91450",
   "metadata": {},
   "source": [
    "## 3. User with user access code event"
   ]
  },
  {
   "cell_type": "raw",
   "id": "827e0986",
   "metadata": {},
   "source": [
    "SELECT\n",
    "  DISTINCT (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST(user_properties)\n",
    "  WHERE\n",
    "    key = \"user_id\") AS user_id,\n",
    "  (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST(user_properties)\n",
    "  WHERE\n",
    "    key = \"name\") AS name,\n",
    "    (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST(event_params)\n",
    "  WHERE\n",
    "    key = \"is_debug_mode\") AS is_debug_mode,\n",
    "FROM\n",
    "  `project.dataset.events_*`\n",
    "WHERE\n",
    "  \n",
    "  user_id IS NOT NULL"
   ]
  },
