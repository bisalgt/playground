   "id": "d3f237ac",
   "metadata": {},
   "source": [
    "## 7. Active user daily, week, month"
   ]
  },
  {
   "cell_type": "raw",
   "id": "004273a2",
   "metadata": {},
   "source": [
    "DECLARE\n",
    "  till_date DATE DEFAULT CURRENT_DATE()-1; # Last Date to which you want the results\n",
    "DECLARE\n",
    "  NDAYS INT64 DEFAULT 30;\n",
    "CREATE OR REPLACE TABLE\n",
    "  `project.dataset.Active_Users` AS\n",
    "WITH\n",
    "  Users AS (\n",
    "  SELECT\n",
    "    DISTINCT user_pseudo_id,\n",
    "    user_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    user_id IS NOT NULL),\n",
    "  usersdata AS (\n",
    "  SELECT\n",
    "    PARSE_DATE('%Y%m%d',\n",
    "      event_date) Date,\n",
    "    user_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    Event_name = 'user_engagement'\n",
    "    AND PARSE_DATE('%Y%m%d',\n",
    "      event_date) <= till_date),\n",
    "  daysN AS (\n",
    "  SELECT\n",
    "    *\n",
    "  FROM\n",
    "    usersdata\n",
    "  WHERE\n",
    "    Date >= DATE_ADD(till_date, INTERVAL -NDAYS DAY)),\n",
    "  days60 AS (\n",
    "  SELECT\n",
    "    *\n",
    "  FROM\n",
    "    usersdata\n",
    "  WHERE\n",
    "    Date >= DATE_ADD(till_date, INTERVAL -60 DAY) ),\n",
    "  endday AS (\n",
    "  SELECT\n",
    "    DISTINCT Date AS stopday\n",
    "  FROM\n",
    "    usersdata\n",
    "  WHERE\n",
    "    Date >= DATE_ADD(till_date, INTERVAL -NDAYS DAY) ),\n",
    "  MonthlyUsers AS (\n",
    "  SELECT\n",
    "    stopday,\n",
    "    COUNT(DISTINCT(user_id)) MAU\n",
    "  FROM\n",
    "    days60\n",
    "  JOIN\n",
    "    endday\n",
    "  ON\n",
    "    Date >= DATE_ADD(stopday, INTERVAL -NDAYS DAY)\n",
    "    AND Date <= stopday\n",
    "  GROUP BY\n",
    "    stopday),\n",
    "  WeeklyUsers AS (\n",
    "  SELECT\n",
    "    stopday,\n",
    "    COUNT(DISTINCT(user_id)) WAU\n",
    "  FROM\n",
    "    days60\n",
    "  JOIN\n",
    "    endday\n",
    "  ON\n",
    "    Date >= DATE_ADD(stopday, INTERVAL -6 DAY)\n",
    "    AND Date <= stopday\n",
    "  GROUP BY\n",
    "    stopday)\n",
    "SELECT\n",
    "  Date,\n",
    "  DAU,\n",
    "  WAU,\n",
    "  MAU,\n",
    "  100 * DAU/WAU AS DAUWAU,\n",
    "  100 * WAU/MAU AS WAUMAU\n",
    "FROM (\n",
    "  SELECT\n",
    "    Date,\n",
    "    COUNT(DISTINCT user_id) DAU,\n",
    "    (\n",
    "    SELECT\n",
    "      MAU\n",
    "    FROM\n",
    "      MonthlyUsers\n",
    "    WHERE\n",
    "      a.Date = MonthlyUsers.stopday) MAU,\n",
    "    (\n",
    "    SELECT\n",
    "      WAU\n",
    "    FROM\n",
    "      WeeklyUsers\n",
    "    WHERE\n",
    "      a.Date = WeeklyUsers.stopday) WAU\n",
    "  FROM\n",
    "    daysN a\n",
    "  GROUP BY\n",
    "    Date )\n",
    "ORDER BY\n",
    "  Date DESC"
   ]
  },
