{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "754c2438",
   "metadata": {},
   "source": [
    "## 1. Engagement Type for different screen type"
   ]
  },
  {
   "cell_type": "raw",
   "id": "5577e637",
   "metadata": {},
   "source": [
    "WITH\n",
    "  screen_type AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    event_timestamp,\n",
    "    user_id,\n",
    "    CONCAT(event_date, \"-\", event_timestamp, user_id) AS time_stamp_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key='email') AS email,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST (event_params)\n",
    "    WHERE\n",
    "      Key='firebase_screen') AS screens,\n",
    "  FROM\n",
    "    `project.dataset.events_*`,\n",
    "    UNNEST(event_params) event\n",
    "  WHERE\n",
    "    event_name='screen_view'\n",
    "    AND event.key = 'firebase_screen'\n",
    "    AND event.value.string_value IS NOT NULL\n",
    "    AND user_id IS NOT NULL\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  engagement_table AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    event_timestamp,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.int_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = 'engagement_time_msec') AS engagement_time,\n",
    "    CONCAT(event_date, \"-\", event_timestamp, user_id) AS engagement_time_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='user_engagement'\n",
    "    AND user_id IS NOT NULL\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  engagement_time_and_screen_type AS (\n",
    "  SELECT\n",
    "    t1.event_date,\n",
    "    t1.screens,\n",
    "    t2.engagement_time\n",
    "  FROM\n",
    "    screen_type t1\n",
    "  JOIN\n",
    "    engagement_table t2\n",
    "  ON\n",
    "    t1.time_stamp_id=t2.engagement_time_id\n",
    "  ORDER BY\n",
    "    event_date DESC,\n",
    "    t2.engagement_time DESC )\n",
    "  -- select sum(engagement_time)/60000 from engagement_time_and_screen_type where screens=\"SettingsScreen\"\n",
    "  -- , temp as (select t1.user_id, t1.screens, t2.engagement_time from screen_type t1 join engagement_table t2 on t1.time_stamp_id = t2.engagement_time_id where t1.screens = \"SettingsScreen\")\n",
    "  -- select sum(engagement_time)/60000 from temp\n",
    "SELECT\n",
    "  screens,\n",
    "  SUM(engagement_time)/60000 total_duration_in_minutes\n",
    "FROM\n",
    "  engagement_time_and_screen_type\n",
    "GROUP BY\n",
    "  screens\n",
    "ORDER BY\n",
    "  total_duration_in_minutes DESC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "75fc4318",
   "metadata": {},
   "source": [
    "## 2. share_app"
   ]
  },
  {
   "cell_type": "raw",
   "id": "af2cc2c6",
   "metadata": {},
   "source": [
    "WITH\n",
    "  share_app AS (\n",
    "  SELECT\n",
    "    DISTINCT parse_DATE(\"%Y%m%d\",\n",
    "      event_date) AS date,\n",
    "    event_timestamp,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key= \"email\") AS email\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name = \"share_app\"\n",
    "    AND user_id IS NOT NULL\n",
    "  ORDER BY\n",
    "    date DESC),\n",
    "  daily_app_share_count AS (\n",
    "  SELECT\n",
    "    date,\n",
    "    COUNT(date) daily_count\n",
    "  FROM\n",
    "    share_app\n",
    "  GROUP BY\n",
    "    date\n",
    "  ORDER BY\n",
    "    date DESC),\n",
    "  weekly_app_share AS (\n",
    "  SELECT\n",
    "    DISTINCT t1.date,\n",
    "    t2.event_timestamp,\n",
    "    t2.email\n",
    "  FROM\n",
    "    share_app t1\n",
    "  JOIN\n",
    "    share_app t2\n",
    "  ON\n",
    "    DATE_DIFF(t1.date, t2.date, day) >= 0\n",
    "    AND DATE_DIFF(t1.date, t2.date, day) <= 6),\n",
    "  monthly_app_share AS (\n",
    "  SELECT\n",
    "    DISTINCT t1.date,\n",
    "    t2.event_timestamp,\n",
    "    t2.email\n",
    "  FROM\n",
    "    share_app t1\n",
    "  JOIN\n",
    "    share_app t2\n",
    "  ON\n",
    "    DATE_DIFF(t1.date, t2.date, day) >= 0\n",
    "    AND DATE_DIFF(t1.date, t2.date, day) <= 29),\n",
    "  weekly_app_share_count AS (\n",
    "  SELECT\n",
    "    date,\n",
    "    COUNT(date) weekly_count\n",
    "  FROM\n",
    "    weekly_app_share\n",
    "  GROUP BY\n",
    "    date\n",
    "  ORDER BY\n",
    "    date DESC),\n",
    "  monthly_app_share_count AS (\n",
    "  SELECT\n",
    "    date,\n",
    "    COUNT(date) monthly_count\n",
    "  FROM\n",
    "    monthly_app_share\n",
    "  GROUP BY\n",
    "    date\n",
    "  ORDER BY\n",
    "    date DESC)\n",
    "  -- select * from share_app\n",
    "  -- select * from daily_app_share\n",
    "  -- select * from daily_app_share;\n",
    "  -- select date, count(date) from weekly_app_share group by date order by date desc;\n",
    "  -- select date, count(date) from monthly_app_share group by date order by date desc;\n",
    "SELECT\n",
    "  t1.date,\n",
    "  t1.daily_count,\n",
    "  t2.weekly_count,\n",
    "  t3.monthly_count\n",
    "FROM\n",
    "  daily_app_share_count t1\n",
    "JOIN\n",
    "  weekly_app_share_count t2\n",
    "ON\n",
    "  t1.date = t2.date\n",
    "JOIN\n",
    "  monthly_app_share_count t3\n",
    "ON\n",
    "  t1.date = t3.date\n",
    "ORDER BY\n",
    "  date DESC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ba8688cd",
   "metadata": {},
   "source": [
    "## 3. video Source"
   ]
  },
  {
   "cell_type": "raw",
   "id": "9e78355a",
   "metadata": {},
   "source": [
    "create or replace table `project.dataset.delete_me_video_source` as \n",
    "\n",
    "WITH\n",
    "  video_source AS (\n",
    "  SELECT\n",
    "  --distinct\n",
    "    event_date,\n",
    "    user_id,\n",
    "    event_timestamp,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key=\"video_source_name\") AS source_of_video,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key=\"category_name\") AS category_of_video\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name =\"video_source\"\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "  -- select type_of_screen, count(type_of_screen) count from screen_type group by type_of_screen order by count desc\n",
    "  -- select distinct type_of_screen from screen_type\n",
    "  -- select * from `project.dataset.events_*` where event_name = \"video_start\" order by event_date desc\n",
    "  -- select source_of_video, category_of_video, count(source_of_video) count from video_source group by source_of_video, category_of_video order by count desc\n",
    "SELECT\n",
    "event_date,\n",
    "  source_of_video,\n",
    "  COUNT(source_of_video) count\n",
    "FROM\n",
    "  video_source\n",
    "GROUP BY\n",
    "event_date,\n",
    "  source_of_video\n",
    "  order by event_date desc, count desc\n",
    "  -- select * from `project.dataset.events_*` where event_name =\"video_source\""
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c1033220",
   "metadata": {},
   "source": [
    "## 4. All Video Start"
   ]
  },
  {
   "cell_type": "raw",
   "id": "f169216b",
   "metadata": {},
   "source": [
    "WITH\n",
    "  users AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    event_name,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key=\"video_title\") AS video_title\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  all_video_start AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id,\n",
    "    video_title\n",
    "  FROM\n",
    "    users\n",
    "  WHERE\n",
    "    event_name = \"video_start\"),\n",
    "  all_video_complete AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id,\n",
    "    video_title\n",
    "  FROM\n",
    "    users\n",
    "  WHERE\n",
    "    event_name = \"complete_watch_video\"),\n",
    "  all_video_start_count AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    COUNT(event_date) count_start\n",
    "  FROM\n",
    "    all_video_start\n",
    "  GROUP BY\n",
    "    event_date\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  all_video_complete_count AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    COUNT(event_date) count_complete\n",
    "  FROM\n",
    "    all_video_complete\n",
    "  GROUP BY\n",
    "    event_date\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "SELECT\n",
    "  t1.event_date,\n",
    "  t1.count_start,\n",
    "  t2.count_complete\n",
    "FROM\n",
    "  all_video_start_count AS t1\n",
    "JOIN\n",
    "  all_video_complete_count AS t2\n",
    "ON\n",
    "  t1.event_date=t2.event_date\n",
    "ORDER BY\n",
    "  t1.event_date DESC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2a34f30c",
   "metadata": {},
   "source": [
    "## 5. watch video half numbers"
   ]
  },
  {
   "cell_type": "raw",
   "id": "e8533b25",
   "metadata": {},
   "source": [
    "CREATE OR REPLACE TABLE\n",
    "  `project.dataset.all_users_video_watch_events` AS\n",
    "WITH\n",
    "  video_events AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    event_name,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key=\"name\") AS user_name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key=\"video_title\") AS video_title\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name IN ('video_start',\n",
    "      'watch_video_half',\n",
    "      'complete_watch_video')\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "SELECT\n",
    "  event_date,\n",
    "  event_name\n",
    "FROM\n",
    "  video_events\n",
    "ORDER BY\n",
    "  event_date DESC,\n",
    "  event_name"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6bdacd71",
   "metadata": {},
   "source": [
    "## 6. Video Watch count with creator name"
   ]
  },
  {
   "cell_type": "raw",
   "id": "50aa9da0",
   "metadata": {},
   "source": [
    "WITH\n",
    "  watched_video AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    event_name,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"video_uuid\") AS video_uuid,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"video_title\") AS video_title\n",
    "  FROM\n",
    "    `project.dataset.events_*`,\n",
    "    UNNEST(event_params) event\n",
    "  WHERE\n",
    "    event_name = \"video_start\"\n",
    "    AND event.key = \"video_uuid\"AND event.value IS NOT NULL),\n",
    "  watched_video_count AS (\n",
    "  SELECT\n",
    "    video_uuid,\n",
    "    COUNT(video_uuid) count\n",
    "  FROM\n",
    "    watched_video\n",
    "  GROUP BY\n",
    "    video_uuid\n",
    "  ORDER BY\n",
    "    count DESC),\n",
    "  video_uuid_with_title_and_creator AS (\n",
    "  SELECT\n",
    "    DISTINCT (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"video_uuid\")AS video_uuid,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"video_title\")AS video_title,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"creator_name\")AS creator_name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"creator_id\")AS creator_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name = \"video_start\" )\n",
    "SELECT\n",
    "  t2.video_title,\n",
    "  t1.count,\n",
    "  t2.creator_name\n",
    "FROM\n",
    "  watched_video_count t1\n",
    "JOIN\n",
    "  video_uuid_with_title_and_creator t2\n",
    "ON\n",
    "  t1.video_uuid = t2.video_uuid\n",
    "ORDER BY\n",
    "  t1.count DESC"
   ]
  }
 ],
