   "source": [
    "SELECT DISTINCT\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"name\") AS name,\n",
    "  FROM\n",
    "    `project.dataset.events_*`"
   ]
