   "cell_type": "markdown",
   "id": "134f7708",
   "metadata": {},
   "source": [
    "## 6. Average Engagement time per screen by User"
   ]
  },
  {
   "cell_type": "raw",
   "id": "9b8288b6",
   "metadata": {},
   "source": [
    "WITH\n",
    "  screen_type AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    event_timestamp,\n",
    "    user_pseudo_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST (event_params)\n",
    "    WHERE\n",
    "      Key='firebase_screen') AS screens,\n",
    "  FROM\n",
    "    `project.dataset.events_*`,\n",
    "    UNNEST(event_params) event\n",
    "  WHERE\n",
    "    event_name='screen_view'\n",
    "    AND event.key = 'firebase_screen'\n",
    "    AND event.value.string_value IS NOT NULL\n",
    "  ORDER BY\n",
    "    event_date DESC),\n",
    "  engagement_table AS (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    event_timestamp,\n",
    "    user_pseudo_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.int_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = 'engagement_time_msec') AS engagement_time\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='user_engagement'\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "SELECT\n",
    "  screen_type.screens,\n",
    "  AVG(engagement_table.engagement_time) as average_time_spent,\n",
    "FROM\n",
    "  engagement_table,\n",
    "  screen_type\n",
    "WHERE\n",
    "  screen_type.event_timestamp = engagement_table.event_timestamp\n",
    "  AND screen_type.user_pseudo_id = engagement_table.user_pseudo_id\n",
    "\n",
    "  GROUP BY screen_type.screens\n",
    "  ORDER By average_time_spent DESC"
   ]
  },
