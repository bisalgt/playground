  {
   "cell_type": "markdown",
   "id": "dba18a37",
   "metadata": {},
   "source": [
    "## 5. All user video watch Event "
   ]
  },
  {
   "cell_type": "raw",
   "id": "b155167e",
   "metadata": {},
   "source": [
    "CREATE OR REPLACE TABLE\n",
    "  `project.dataset.all_users_video_watch_events` AS\n",
    "WITH\n",
    "  video_events AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    event_name,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key=\"name\") AS user_name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key=\"video_title\") AS video_title\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name IN ('video_start',\n",
    "      'watch_video_half',\n",
    "      'complete_watch_video')\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "SELECT\n",
    "  event_date,\n",
    "  event_name\n",
    "FROM\n",
    "  video_events\n",
    "ORDER BY\n",
    "  event_date DESC,\n",
    "  event_name"
   ]
  },
