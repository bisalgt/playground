   "source": [
    "## 1. BackUP Query"
   ]
  },
  {
   "cell_type": "raw",
   "id": "2f4efc0c",
   "metadata": {},
   "source": [
    "DECLARE\n",
    "  min_date Date;\n",
    "SET\n",
    "  min_date =(\n",
    "  SELECT\n",
    "    MIN(parse_DATE(\"%Y%m%d\",\n",
    "        event_date))\n",
    "  FROM\n",
    "    `project.dataset.events_*`);\n",
    "EXECUTE IMMEDIATE\n",
    "  FORMAT('''\n",
    "create or replace table `project.dataset.backup_%s` as\n",
    "select * from `project.dataset.events_*` where parse_date(\"%%Y%%m%%d\", event_date) = Date('%t')\n",
    "''',STRING(min_date), min_date)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8aaf04eb",
   "metadata": {},
   "source": [
    "## 2. Watched Videos Details"
   ]
  },
  {
   "cell_type": "raw",
   "id": "07108296",
   "metadata": {},
   "source": [
    "CREATE OR REPLACE TABLE\n",
    "  `project.dataset.watched_videos_details` AS\n",
    "WITH\n",
    "  watched_video AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    event_name,\n",
    "    user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"name\") AS user_name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"email\") AS user_email,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"video_uuid\") AS video_uuid,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"video_title\") AS video_title,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"creator_name\") AS creator_name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"creator_id\")AS creator_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name IN UNNEST([\"video_start\", \"complete_watch_video\", \"watch_video_half\"])),\n",
    "  watched_video_with_developer_tags AS (\n",
    "  SELECT\n",
    "    t1.*,\n",
    "  IF\n",
    "    (LOWER(user_email) IN (\n",
    "      SELECT\n",
    "        LOWER(email)\n",
    "      FROM\n",
    "        `project.dataset.developers`)\n",
    "      OR REGEXP_CONTAINS(LOWER(user_email), r'.*@yopmail.com$'),\n",
    "      TRUE,\n",
    "      FALSE) AS is_developer\n",
    "  FROM\n",
    "    watched_video t1 )\n",
    "SELECT\n",
    "  *\n",
    "FROM\n",
    "  watched_video_with_developer_tags;"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2cb1df8d",
   "metadata": {},
   "source": [
    "## 3. App Uninstall"
   ]
  },
  {
   "cell_type": "raw",
   "id": "b2f1a27b",
   "metadata": {},
   "source": [
    "WITH\n",
    "  app_remove AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id,\n",
    "    user.value.string_value AS email\n",
    "  FROM\n",
    "    `project.dataset.events_*`,\n",
    "    UNNEST(user_properties) user\n",
    "  WHERE\n",
    "    event_name = \"app_remove\"\n",
    "    AND user.key = \"email\"),\n",
    "  user_access_code AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id,\n",
    "    event.value.string_value AS access_code\n",
    "  FROM\n",
    "    `project.dataset.events_*`,\n",
    "    UNNEST(event_params) event\n",
    "  WHERE\n",
    "    event_name = \"user_access_code\"\n",
    "    AND event.key = \"access_code\"),\n",
    "  app_remover_excluding_developers AS (\n",
    "  SELECT\n",
    "    DISTINCT t1.event_date,\n",
    "    t1.user_id,\n",
    "    t1.email\n",
    "  FROM\n",
    "    app_remove t1\n",
    "  JOIN\n",
    "    user_access_code t2\n",
    "  ON\n",
    "    t1.user_id = t2.user_id\n",
    "  WHERE\n",
    "    t2.access_code NOT IN UNNEST([\"insight1\", \"insight-stg\",\"insight-stgtwo\"])\n",
    "  ORDER BY\n",
    "    t1.event_date DESC)\n",
    "SELECT\n",
    "  event_date,\n",
    "  COUNT(event_date)\n",
    "FROM\n",
    "  app_remover_excluding_developers\n",
    "GROUP BY\n",
    "  event_date\n",
    "ORDER BY\n",
    "  event_date DESC"
   ]
  },
  {
