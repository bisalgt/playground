    "## 9. Daily Active Users"
   ]
  },
  {
   "cell_type": "raw",
   "id": "1e15ef6f",
   "metadata": {},
   "source": [
    "WITH\n",
    "  user_data AS (\n",
    "  SELECT\n",
    "    *, (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST(user_properties)\n",
    "  WHERE\n",
    "    key= \"email\") AS email\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name = \"user_engagement\" and parse_date('%Y%m%d',event_date) <= date_sub(current_date(), INTERVAL 1 DAY)),\n",
    "    dau as (\n",
    "SELECT\n",
    "  distinct event_date, user_pseudo_id\n",
    "FROM\n",
    "  user_data\n",
    "WHERE\n",
    "  lower(email) not in (select lower(Email) from project.dataset.developers) or lower(email) is null\n",
    "-- group by event_date\n",
    "order by event_date desc)\n",
    "-- select event_date, count(event_date) as daily_active_user_count from dau group by event_date order by event_date desc\n",
    "select * from dau"
   ]
