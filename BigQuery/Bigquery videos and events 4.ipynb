   "source": [
    "## 1. Email of Developers"
   ]
  },
  {
   "cell_type": "raw",
   "id": "7cd90355",
   "metadata": {},
   "source": [
    "SELECT\n",
    "  DISTINCT (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST (user_properties)\n",
    "  WHERE\n",
    "    key='email') AS email\n",
    "FROM\n",
    "  `project.dataset.events_*`\n",
    "WHERE\n",
    "  (\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST (user_properties)\n",
    "  WHERE\n",
    "    key='email') IS NOT NULL\n",
    "    AND  REGEXP_CONTAINS((\n",
    "  SELECT\n",
    "    value.string_value\n",
    "  FROM\n",
    "    UNNEST (user_properties)\n",
    "  WHERE\n",
    "    key='email'), r\"something|something\") "
   ]
  },
