   "cell_type": "markdown",
   "id": "8b10b51f",
   "metadata": {},
   "source": [
    "## 3. Engagement Time"
   ]
  },
  {
   "cell_type": "raw",
   "id": "ad847b01",
   "metadata": {},
   "source": [
    "SELECT\n",
    "  event_date,\n",
    "  event_timestamp,\n",
    "  user_pseudo_id,\n",
    "  (\n",
    "  SELECT\n",
    "    value.int_value\n",
    "  FROM\n",
    "    UNNEST(event_params)\n",
    "  WHERE\n",
    "    key = 'engagement_time_msec') AS engagement_time\n",
    "FROM\n",
    "  `project.dataset.events_*`\n",
    "WHERE\n",
    "  event_name='user_engagement'\n",
    "ORDER BY\n",
    "  event_date DESC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3685ca11",
   "metadata": {},
   "source": [
    "## 4. Improved Weekly Data User"
   ]
  },
  {
   "cell_type": "raw",
   "id": "b5ddcfd4",
   "metadata": {},
   "source": [
    "WITH\n",
    "  users AS (\n",
    "  SELECT\n",
    "    DISTINCT event_date,\n",
    "    user_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name = \"user_engagement\"\n",
    "    AND user_id IS NOT NULL\n",
    "  ORDER BY\n",
    "    event_date DESC)\n",
    "\n",
    "\n",
    "SELECT distinct\n",
    "  t1.event_date,\n",
    "  count(distinct(t2.user_id))\n",
    "FROM\n",
    "  users t1\n",
    "JOIN\n",
    "  users t2\n",
    "ON\n",
    "  DATE_DIFF(parse_DATE(\"%Y%m%d\",\n",
    "      t1.event_date), parse_DATE(\"%Y%m%d\",\n",
    "      t2.event_date), DAY) <= 6 and DATE_DIFF(parse_DATE(\"%Y%m%d\",\n",
    "      t1.event_date), parse_DATE(\"%Y%m%d\",\n",
    "      t2.event_date), DAY) >= 0\n",
    "GROUP BY\n",
    "t1.event_date\n",
    "order by t1.event_date desc"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "475b3c69",
   "metadata": {},
   "source": [
    "## 5. App Remove Query "
   ]
  },
  {
   "cell_type": "raw",
   "id": "44b6b55c",
   "metadata": {},
   "source": [
    "SELECT\n",
    "  DISTINCT Table2.user_id,\n",
    "  Table1.name,\n",
    "  Table2.access_code,\n",
    "  Table1.event_date\n",
    "FROM (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"name\") AS name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='app_remove'\n",
    "    AND (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") IS NOT NULL\n",
    "  ORDER BY\n",
    "    event_date DESC) AS Table1\n",
    "JOIN (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"name\") AS name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"access_code\") AS access_code,\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='user_access_code'\n",
    "    AND (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"access_code\") NOT IN ('sth1',\n",
    "      'sth-stg',\n",
    "      'sth-stgtwo')\n",
    "    AND (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") IS NOT NULL\n",
    "  ORDER BY\n",
    "    event_date DESC) AS Table2\n",
    "ON\n",
    "  Table1.user_id = Table2.user_id\n",
    "ORDER BY\n",
    "  Table1.event_date DESC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d170f210",
   "metadata": {},
   "source": [
    "## 6. Join Query User Event"
   ]
  },
  {
   "cell_type": "raw",
   "id": "60fa20cb",
   "metadata": {},
   "source": [
    "SELECT DISTINCT Table2.user_id, Table1.name, Table1.event_date\n",
    "FROM (\n",
    "  SELECT\n",
    "    event_date,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"name\") AS name,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='app_remove') AS Table1\n",
    " JOIN (\n",
    "  SELECT\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='user_access_code'\n",
    "    AND (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"access_code\") != 'sth') AS Table2\n",
    "ON\n",
    "  Table1.user_id = Table2.user_id\n",
    "  "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "265e5960",
   "metadata": {},
   "source": [
    "## 7. App remove query latest"
   ]
  },
  {
   "cell_type": "raw",
   "id": "155d2141",
   "metadata": {},
   "source": [
    "WITH\n",
    "  TotalExitedUsers AS (\n",
    "  SELECT\n",
    "    DISTINCT (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id,\n",
    "    event_date,\n",
    "    (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"is_debug_mode\") AS is_debug_mode\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name='app_remove'\n",
    "    AND user_id IS NOT NULL\n",
    "    AND NOT REGEXP_CONTAINS((SELECT value.string_value FROM UNNEST (user_properties) WHERE key=\"email\"), r\"sth|sth2\")\n",
    "    AND ((\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"is_debug_mode\") != 'true' OR (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(event_params)\n",
    "    WHERE\n",
    "      key = \"is_debug_mode\") IS NULL )),\n",
    "  UserWithoutUserAccessCodeEvent AS (\n",
    "  SELECT\n",
    "    DISTINCT (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name != 'user_access_code'),\n",
    "  UserWithUserAccessCodeEvent AS (\n",
    "  SELECT\n",
    "    DISTINCT (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST(user_properties)\n",
    "    WHERE\n",
    "      key = \"user_id\") AS user_id\n",
    "  FROM\n",
    "    `project.dataset.events_*`\n",
    "  WHERE\n",
    "    event_name = 'user_access_code'\n",
    "    AND (\n",
    "    SELECT\n",
    "      value.string_value\n",
    "    FROM\n",
    "      UNNEST (event_params)\n",
    "    WHERE\n",
    "      key='access_code') NOT IN (\"sth1\",\n",
    "      \"sth-dev\",\n",
    "      \"sth-stgtwo\"))\n",
    "SELECT\n",
    "  user_id,\n",
    "  event_date, is_debug_mode\n",
    "FROM (\n",
    "  SELECT\n",
    "    user_id,\n",
    "    event_date, is_debug_mode\n",
    "  FROM\n",
    "    TotalExitedUsers\n",
    "  WHERE\n",
    "    TotalExitedUsers.user_id NOT IN (\n",
    "    SELECT\n",
    "      user_id\n",
    "    FROM\n",
    "      UserWithUserAccessCodeEvent)\n",
    "    OR TotalExitedUsers.user_id IN (\n",
    "    SELECT\n",
    "      user_id\n",
    "    FROM\n",
    "      UserWithoutUserAccessCodeEvent))\n",
    "ORDER BY\n",
    "  event_date DESC"
   ]
  },
